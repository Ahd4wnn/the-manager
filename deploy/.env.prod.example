# Copy to .env.prod on the VPS and fill with real secrets. NEVER commit .env.prod.
# Generate strong values:
#   SECRET_KEY:  openssl rand -base64 48
#   passwords:   openssl rand -base64 24

ENVIRONMENT=production
DEBUG=false

SECRET_KEY=__CHANGE_ME__
ACCESS_TOKEN_EXPIRE_MINUTES=1440

POSTGRES_USER=bmw
POSTGRES_PASSWORD=__CHANGE_ME__
POSTGRES_DB=bmw_manager
POSTGRES_PORT=5432

# First platform admin created on first boot
FIRST_ADMIN_PHONE=9999999999
FIRST_ADMIN_PASSWORD=__CHANGE_ME__
FIRST_ADMIN_NAME=Platform Admin

# Allowed browser origins for the admin panel
CORS_ORIGINS=https://admin.bmwholistics.in
