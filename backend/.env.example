# --- App ---
APP_NAME=BMW The Manager
ENVIRONMENT=development
DEBUG=true

# --- Security ---
# Generate a strong key: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ALGORITHM=HS256

# --- Database ---
POSTGRES_USER=bmw
POSTGRES_PASSWORD=bmw_password
POSTGRES_HOST=localhost
# 5433 to avoid clashing with a local PostgreSQL install on 5432
POSTGRES_PORT=5433
POSTGRES_DB=bmw_manager
# Optional full override; if empty it is built from the parts above.
DATABASE_URL=

# --- Platform admin (created by `python -m app.seed`) ---
FIRST_ADMIN_PHONE=9999999999
FIRST_ADMIN_PASSWORD=admin12345
FIRST_ADMIN_NAME=Platform Admin

# --- CORS (comma-separated origins for the React admin panel) ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
